# Copy to .env and fill in your API keys. Never commit .env to git.

# Deepgram Nova-3 (baseline) — https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Sarvam Saaras v3 — https://dashboard.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# Path to recordings folder
RECORDINGS_DIR=./recordings

# Skip failed models instead of crashing
FAIL_GRACEFULLY=true

# Whisper model size: tiny / base / small / medium / large-v3
WHISPER_MODEL_SIZE=medium

# AI4Bharat IndicConformer model ID
INDICCONFORMER_MODEL=ai4bharat/indicconformer_stt_hi_hybrid_rnnt_large